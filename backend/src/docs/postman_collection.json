    {
      "name": "Resources Hub",
      "item": [
        {
          "name": "Request Resource Upload",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Computer Networks Lecture Notes", "type": "text" },
                { "key": "description", "value": "TCP/IP, subnetting, and application layer notes.", "type": "text" },
                { "key": "category", "value": "notes", "type": "text" },
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/resources/request",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "request"]
            }
          }
        },
        {
          "name": "List Resources (Paginated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/resources?page=1&limit=10&category=notes",
              "host": ["{{baseUrl}}"],
              "path": ["resources"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "category", "value": "notes" }
              ]
            }
          }
        },
        {
          "name": "Toggle Resource Like",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/resources/:id/like",
              "host": ["{{baseUrl}}"],
              "path": ["resources", ":id", "like"],
              "variable": [
                { "key": "id", "value": "resource_id_here" }
              ]
            }
          }
        }
      ]
    },
