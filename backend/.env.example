# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/helping_society?retryWrites=true&w=majority

# JWT Configurations
JWT_SECRET=your_jwt_access_token_secret_minimum_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_minimum_64_characters

# Cloudinary Storage Credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Dispatch Configurations (SMTP/Mailtrap/Gmail)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@uecu.ac.in

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Auth0 Configurations
AUTH0_DOMAIN=your_auth0_domain
AUTH0_CLIENT_ID=your_auth0_client_id
